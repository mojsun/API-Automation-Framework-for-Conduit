{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "description": "Conduit API error response - may have 'errors' object or message",
  "oneOf": [
    {
      "type": "object",
      "required": ["errors"],
      "properties": {
        "errors": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "type": "object",
      "required": ["message"],
      "properties": {
        "message": { "type": "string" }
      },
      "additionalProperties": true
    }
  ]
}
